---
// An imagery slot. With `src` it renders a real (lazy, cover-fit) photo over the
// dark gradient; without one it stays an intentional placeholder (gradient +
// diamond-dust + reflection). object-position is set via a class (CSP: no inline styles).
interface Props {
  ratio?: string; // a Tailwind aspect-* class
  label?: string;
  src?: string;
  alt?: string;
  position?: string; // a Tailwind object-* class, e.g. object-center / object-top
  class?: string;
}
const {
  ratio = 'aspect-[4/3]',
  label,
  src,
  alt = '',
  position = 'object-center',
  class: className = '',
} = Astro.props;
---

<div
  class:list={[
    'group relative overflow-hidden rounded-2xl border border-champagne/15 bg-gradient-to-br from-midnight-soft via-obsidian to-midnight',
    ratio,
    className,
  ]}
>
  <div class="diamond-grid absolute inset-0 opacity-60" aria-hidden="true"></div>
  {
    src ? (
      <Fragment>
        <img
          src={src}
          alt={alt}
          loading="lazy"
          decoding="async"
          class:list={[
            'absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-luxe group-hover:scale-[1.04]',
            position,
          ]}
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-obsidian/70 via-transparent to-transparent"
          aria-hidden="true"
        />
      </Fragment>
    ) : (
      <div class="absolute inset-0" />
    )
  }
  <slot />
  {label && <span class="eyebrow absolute bottom-4 left-5 text-crystal">{label}</span>}
</div>
