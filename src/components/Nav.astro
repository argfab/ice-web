---
import IceMark from './IceMark.astro';
import IceWordmark from './IceWordmark.astro';

interface Props {
  variant?: 'solid' | 'overlay';
}
const { variant = 'solid' } = Astro.props;

const links = [
  { href: '/the-house', label: 'The House' },
  { href: '/experiences', label: 'Experiences' },
  { href: '/destinations', label: 'Destinations' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/approach', label: 'Approach' },
  { href: '/recognition', label: 'Recognition' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isOverlay = variant === 'overlay';

const wrapClass = isOverlay
  ? 'absolute inset-x-0 top-0 z-40'
  : 'sticky top-0 z-40 border-b border-silver/10 bg-obsidian/80 backdrop-blur-xl';
---

<header class={wrapClass}>
  <nav class="container-prose flex items-center justify-between py-5" aria-label="Primary">
    <a href="/" class="flex items-center gap-3 text-crystal" aria-label="ICE — home">
      <IceMark class="h-8 w-8 text-champagne" />
      <IceWordmark class="text-xl" sub={false} />
    </a>

    <!-- Desktop -->
    <ul class="hidden items-center gap-7 lg:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class="link-underline font-sans text-sm text-silver hover:text-crystal"
              aria-current={path === l.href ? 'page' : undefined}
            >
              {l.label}
            </a>
          </li>
        ))
      }
      <li><a href="/apply" class="btn-gold !px-6 !py-2.5 text-xs">Begin Your Journey</a></li>
    </ul>

    <!-- Mobile (CSS-only disclosure) -->
    <details class="group relative lg:hidden">
      <summary
        class="flex cursor-pointer list-none items-center gap-2 font-sans text-sm text-crystal [&::-webkit-details-marker]:hidden"
        aria-label="Open menu"
      >
        Menu
        <span class="inline-block transition-transform duration-300 ease-luxe group-open:rotate-45"
          >+</span
        >
      </summary>
      <div class="glass-card absolute right-0 mt-4 w-60 p-4">
        <ul class="flex flex-col gap-1">
          {
            links.map((l) => (
              <li>
                <a href={l.href} class="block rounded-lg px-3 py-2 text-sm text-silver hover:bg-white/5 hover:text-crystal">
                  {l.label}
                </a>
              </li>
            ))
          }
          <li class="mt-2">
            <a href="/apply" class="btn-gold w-full">Begin Your Journey</a>
          </li>
        </ul>
      </div>
    </details>
  </nav>
</header>
