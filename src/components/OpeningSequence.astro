---
// The opening centrepiece: a gold brilliant-cut diamond that fades in, then stays
// alive — turning slowly on its vertical axis, wrapped in a soft champagne halo,
// with four-point sparkle glints twinkling around it. Pure CSS/SVG (no WebGL this
// phase); the global reduced-motion rule collapses it to a calm, static gem.
import DiamondGold from './DiamondGold.astro';
import IceWordmark from './IceWordmark.astro';
---

<div class="opening flex flex-col items-center gap-9">
  <div class="diamond-stage">
    <div class="diamond-float">
      <div class="gem-halo" aria-hidden="true"></div>
      <div class="gem-spin">
        <DiamondGold class="gem h-36 w-36 sm:h-44 sm:w-44" />
      </div>
      <svg
        class="gem-sparkles"
        viewBox="0 0 200 200"
        fill="none"
        aria-hidden="true"
        focusable="false"
      >
        <defs>
          <radialGradient id="ice-spark-glow">
            <stop offset="0" stop-color="#ffffff" stop-opacity="0.95" />
            <stop offset="1" stop-color="#ffffff" stop-opacity="0" />
          </radialGradient>
        </defs>
        <g transform="translate(86 64)">
          <g class="spark spark-1">
            <circle r="14" fill="url(#ice-spark-glow)" />
            <path d="M0,-9 L1.8,-1.8 L9,0 L1.8,1.8 L0,9 L-1.8,1.8 L-9,0 L-1.8,-1.8 Z" fill="#fff" />
          </g>
        </g>
        <g transform="translate(148 57)">
          <g class="spark spark-2">
            <circle r="9" fill="url(#ice-spark-glow)" />
            <path d="M0,-6 L1.2,-1.2 L6,0 L1.2,1.2 L0,6 L-1.2,1.2 L-6,0 L-1.2,-1.2 Z" fill="#fff" />
          </g>
        </g>
        <g transform="translate(58 97)">
          <g class="spark spark-3">
            <circle r="8" fill="url(#ice-spark-glow)" />
            <path d="M0,-6 L1.2,-1.2 L6,0 L1.2,1.2 L0,6 L-1.2,1.2 L-6,0 L-1.2,-1.2 Z" fill="#fff" />
          </g>
        </g>
        <g transform="translate(104 119)">
          <g class="spark spark-4">
            <circle r="12" fill="url(#ice-spark-glow)" />
            <path d="M0,-7.5 L1.5,-1.5 L7.5,0 L1.5,1.5 L0,7.5 L-1.5,1.5 L-7.5,0 L-1.5,-1.5 Z" fill="#fff" />
          </g>
        </g>
        <g transform="translate(130 80)">
          <g class="spark spark-5">
            <circle r="7" fill="url(#ice-spark-glow)" />
            <path d="M0,-5 L1,-1 L5,0 L1,1 L0,5 L-1,1 L-5,0 L-1,-1 Z" fill="#fff" />
          </g>
        </g>
      </svg>
    </div>
  </div>
  <div class="wordmark text-center">
    <IceWordmark class="text-5xl sm:text-6xl" shimmer={true} />
  </div>
</div>

<style>
  .diamond-stage {
    perspective: 1000px;
  }
  .diamond-float {
    position: relative;
    display: inline-block;
  }
  .gem-spin {
    position: relative;
    z-index: 0;
    transform-style: preserve-3d;
    transform: rotateX(12deg);
    animation: gem-spin-y 18s linear 1.35s infinite;
  }
  .gem {
    display: block;
    filter: drop-shadow(0 12px 26px rgba(0, 0, 0, 0.55)) drop-shadow(0 0 14px rgba(240, 215, 155, 0.22));
    animation: facet-in 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }
  .gem-halo {
    position: absolute;
    inset: -28%;
    z-index: -1;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(240, 215, 155, 0.36),
      rgba(212, 180, 131, 0.12) 42%,
      transparent 68%
    );
    filter: blur(8px);
    animation: gem-halo 5.5s ease-in-out infinite;
  }
  .gem-sparkles {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
    opacity: 0;
    animation: fade-up 1s ease 1.5s forwards;
  }
  .gem-sparkles .spark {
    transform-box: fill-box;
    transform-origin: center;
    animation: gem-spark 3.4s ease-in-out infinite;
  }
  .gem-sparkles .spark-1 {
    animation-delay: 0.2s;
  }
  .gem-sparkles .spark-2 {
    animation-delay: 1.7s;
  }
  .gem-sparkles .spark-3 {
    animation-delay: 0.9s;
  }
  .gem-sparkles .spark-4 {
    animation-delay: 2.5s;
  }
  .gem-sparkles .spark-5 {
    animation-delay: 1.2s;
  }
  .wordmark {
    opacity: 0;
    animation: fade-up 1.1s cubic-bezier(0.22, 1, 0.36, 1) 1.3s both;
  }
</style>
