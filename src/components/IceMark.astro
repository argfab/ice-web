---
// The ICE mark: a brilliant-cut diamond within a thin ring.
// stroke="currentColor" so it takes the surrounding text colour (e.g. text-champagne).
// Named ids (#ice-ring, #ice-diamond, #ice-facets) let the opening sequence — and a
// future WebGL replacement — target the parts without a rewrite. The ring carries
// pathLength="1" for stroke-dashoffset draw animations.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 100 100"
  fill="none"
  stroke="currentColor"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
>
  <circle id="ice-ring" cx="50" cy="50" r="45" stroke-width="0.9" pathLength="1" opacity="0.55" />
  <g id="ice-diamond" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round">
    <path d="M40 34 L60 34 L74 45 L50 73 L26 45 Z" />
  </g>
  <g id="ice-facets" stroke-width="0.65" stroke-linejoin="round" opacity="0.7">
    <path d="M26 45 H74" />
    <path d="M40 34 L33 45" />
    <path d="M60 34 L67 45" />
    <path d="M40 34 L50 45" />
    <path d="M60 34 L50 45" />
    <path d="M50 45 V73" />
    <path d="M33 45 L50 73" />
    <path d="M67 45 L50 73" />
  </g>
</svg>
