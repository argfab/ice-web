---
import IceLogo from './IceLogo.astro';

const year = new Date().getFullYear();
const columns = [
  {
    heading: 'The House',
    links: [
      { href: '/the-house', label: 'The House' },
      { href: '/approach', label: 'Approach' },
      { href: '/recognition', label: 'Recognition' },
    ],
  },
  {
    heading: 'Experiences',
    links: [
      { href: '/experiences', label: 'What We Compose' },
      { href: '/destinations', label: 'Destinations' },
      { href: '/portfolio', label: 'Portfolio' },
    ],
  },
  {
    heading: 'Platform',
    links: [
      { href: '/dream-builder', label: 'Dream Builder' },
      { href: '/enquire', label: 'Private Enquiry' },
      { href: '/apply', label: 'Begin Your Journey' },
    ],
  },
];
---

<footer class="bg-obsidian text-crystal" style="border-top: 1px solid rgba(65,105,225,0.20); box-shadow: 0 -1px 28px rgba(65,105,225,0.08);">
  <div class="container-prose grid gap-12 py-20 md:grid-cols-[1.5fr_1fr_1fr_1fr]">
    <div>
      <IceLogo variant="mark" size="md" class="text-crystal" />
      <p class="mt-6 max-w-xs text-sm leading-relaxed text-silver">
        Bali’s most celebrated luxury event house. Destination weddings, milestone celebrations, curated travel packages, bespoke concierge, and private events — worldwide, by application only.
      </p>
      <a href="/apply" class="btn-gold mt-8">Begin Your Journey</a>
      <p class="mt-5 text-xs text-silver-soft">hello@iceluxuryweddings.com</p>
    </div>

    {
      columns.map((col) => (
        <nav class="footer-col" aria-label={col.heading}>
          <p class="footer-col-heading eyebrow">{col.heading}</p>
          <ul class="mt-5 space-y-3">
            {col.links.map((l) => (
              <li>
                <a href={l.href} class="footer-col-link blue-link link-underline text-sm">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>

  <div style="border-top: 1px solid rgba(65,105,225,0.12);">
    <div
      class="container-prose flex flex-col items-start justify-between gap-3 py-6 text-xs text-silver-soft sm:flex-row sm:items-center"
    >
      <p>&copy; {year} ICE Luxury Weddings &amp; Events. All rights reserved.</p>
      <p class="uppercase tracking-eyebrow">Luxury Wedding Planner · Bali · Worldwide</p>
    </div>
  </div>
</footer>

<style>
  .footer-col-heading {
    color: rgba(200, 190, 180, 0.60);
  }

  .footer-col-link {
    color: rgba(200, 190, 180, 0.65);
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }
  .footer-col-link:hover {
    color: #F4F0EB;
    text-shadow:
      0 0 12px rgba(65, 105, 225, 0.70),
      0 0 28px rgba(27, 58, 140, 0.45);
  }
</style>
