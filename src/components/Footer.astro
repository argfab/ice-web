---
import IceWordmark from './IceWordmark.astro';

const year = new Date().getFullYear();
const columns = [
  {
    heading: 'The House',
    links: [
      { href: '/the-house', label: 'The House' },
      { href: '/approach', label: 'Approach' },
      { href: '/experiences', label: 'Experiences' },
    ],
  },
  {
    heading: 'Work',
    links: [
      { href: '/destinations', label: 'Destinations' },
      { href: '/portfolio', label: 'Portfolio' },
      { href: '/recognition', label: 'Recognition' },
    ],
  },
  {
    heading: 'Connect',
    links: [
      { href: '/enquire', label: 'Private Enquiry' },
      { href: '/apply', label: 'Begin Your Journey' },
    ],
  },
];
---

<footer class="border-t border-silver/10 bg-obsidian text-crystal">
  <div class="container-prose grid gap-12 py-20 md:grid-cols-[1.5fr_1fr_1fr_1fr]">
    <div>
      <IceWordmark class="text-2xl text-crystal" />
      <p class="mt-6 max-w-xs text-sm leading-relaxed text-silver">
        A Bali domiciled atelier composing the world’s most extraordinary celebrations. By application
        only.
      </p>
      <a href="/apply" class="btn-outline mt-8">Begin Your Journey</a>
    </div>

    {
      columns.map((col) => (
        <nav aria-label={col.heading}>
          <p class="eyebrow text-silver-soft">{col.heading}</p>
          <ul class="mt-5 space-y-3">
            {col.links.map((l) => (
              <li>
                <a href={l.href} class="link-underline text-sm text-silver hover:text-crystal">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>

  <div class="border-t border-silver/10">
    <div
      class="container-prose flex flex-col items-start justify-between gap-3 py-6 text-xs text-silver-soft sm:flex-row sm:items-center"
    >
      <p>&copy; {year} ICE Luxury Weddings &amp; Events. All rights reserved.</p>
      <p class="uppercase tracking-eyebrow">Where dreams become legacy</p>
    </div>
  </div>
</footer>
