---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Starfield from '../components/Starfield.astro';
import IceLogo from '../components/IceLogo.astro';
import TeamGrid from '../islands/TeamGrid/TeamGrid.tsx';
import FounderCard from '../islands/FounderCard/FounderCard.tsx';
import HousePromise from '../islands/HousePromise/HousePromise.tsx';

const founders = [
  {
    name: 'Nix',
    role: 'Founder & Creative Director',
    eyebrow: 'The Heart. The Legacy. The Experience.',
    portraitLabel: 'Nix · Portrait to follow',
    image: '/images/founders/nicky.webp',
    quote: 'When love leads the design, every detail becomes a reflection of the heart.',
    bio: [
      "For more than 30 years, Nix has dedicated her life to helping couples celebrate love, connection, family, and the most important days of their lives. Celebrated in international bridal publications and recognised for her bespoke approach to destination weddings, Nix has become synonymous with trust, excellence, and timeless elegance.",
      "“Every wedding I style begins with a heartbeat, yours. The colours, textures, and details are simply the language through which your love story speaks. My greatest joy is bringing your vision to life in a way that feels authentically you, beautiful, intentional, and unforgettable. It's not just about creating something that looks perfect; it's about crafting a moment that feels like home.”",
    ],
  },
  {
    name: 'Tayne',
    role: 'Founder & Director of Innovation',
    eyebrow: 'The Future. The Innovation. The Vision.',
    portraitLabel: 'Tayne · Portrait to follow',
    image: '/images/founders/tayne.webp',
    quote: 'To love is the beginning; to remember, forever. I am but the hand that turns a single day into a story the heart will tell for a lifetime.',
    bio: [
      'Tayne brings a bold and modern approach to luxury celebrations — combining creativity, technology, branding, and experience design to push boundaries and redefine what is possible in the world of luxury weddings and events.',
      'Driven by innovation and a passion for creating extraordinary experiences, he continues to evolve the family legacy into a globally recognised luxury wedding and event brand.',
      'Together with Nix, they are shaping the future of luxury celebrations — ensuring ICE is always a step ahead, without losing an ounce of soul.',
    ],
  },
];

const promises = [
  { title: 'Quality, Never Volume', line: 'We accept a limited number of celebrations each year — never rushed, never repeated.' },
  { title: 'Two Generations, One Standard', line: 'Legacy and innovation answer to the same exacting eye.' },
  { title: 'By Application Only', line: 'We choose our couples as carefully as they choose us.' },
  { title: 'Discretion, Always', line: 'Much of our finest work is known only to those who were there.' },
  { title: 'Composed Worldwide', line: 'Wherever in the world you call us, the standard travels with us.' },
];

const teamMembers = [
  {
    name: 'Yuvi',
    role: 'Wedding Coordinator',
    initial: 'Y',
    image: '/images/team/yuvi.webp',
    caption: 'The coordinator who leads every detail with love and calm.',
    bio: "She has been called the calmest person in any room on any wedding day — and those who have worked with her know exactly why. Yuvi leads not with urgency, but with love: a rare combination of quiet precision and extraordinary warmth. Behind every seamless timeline, every vendor who arrived exactly when they should have, every small crisis averted before anyone even sensed it — there is Yuvi, coordinating with a focus and a devotion that you will feel long before you ever see the results. She does not just coordinate your wedding. She leads it, gently.",
  },
  {
    name: 'Luthfi',
    role: 'Production Manager',
    initial: 'L',
    image: '/images/team/luthfi.webp',
    caption: 'The backbone behind every moment that looks effortless.',
    bio: "Every extraordinary celebration has a backbone. Luthfi is ours. He is the one who never misses a beat — the songs land exactly on cue, the fireworks ignite at precisely the right second, the colour bombs and fire dancers move in perfect rhythm with everything around them. It is all on point, because he is behind it. He orchestrates the world behind the scenes with a calm authority that inspires confidence in every artisan, every technician, every person on site. The extraordinary, in his hands, looks exactly like it was always the plan.",
  },
  {
    name: 'Cetta',
    role: 'Bridal Concierge',
    initial: 'C',
    image: '/images/team/cetta.webp',
    caption: 'The presence who ensures you feel nothing but joy, from first light to last dance.',
    bio: "There are people who understand what it truly means to be a bride — not just the logistics, not just the schedule, but the emotional weight of the day, the way time moves differently, the small moments that quietly become the ones you carry forever. Cetta is one of those people. From the stillness of the morning to the last song of the night, she is the warm, steady presence at your side — anticipating what you need before you need it, holding what you should never have to see, and ensuring that on this day, of all days, you feel nothing but the full beauty of exactly where you are. The couples who have had her beside them will tell you she is irreplaceable. We already knew.",
  },
  {
    name: 'Devereaux',
    role: 'Head of Technology',
    initial: 'D',
    image: '/images/team/devereaux.webp',
    caption: 'The mind that built the platform keeping ICE ten years ahead.',
    bio: "Behind the elegance of every ICE client experience lives a remarkable intelligence — and Devereaux built it. As the architect of the Dream Builder platform, he is the reason couples feel certainty instead of confusion, and ease instead of overwhelm throughout their entire planning journey. Technology, in his hands, becomes invisible — felt only as quiet confidence, seamless clarity, and the reassurance that every detail is precisely where it belongs. He is the reason ICE is ten years ahead of the world it operates in.",
  },
  {
    name: 'Michele',
    role: 'Head of Sales',
    initial: 'M',
    image: '/images/team/michele.webp',
    caption: 'The first voice you hear — and the reason you say yes.',
    bio: "Michele is the first voice you hear — and the reason so many couples say yes before they fully understand why. She possesses a gift that cannot be trained: the ability to listen not just to what a couple wants, but to what they are truly hoping to feel, and to reflect it back with such clarity that the path forward becomes undeniable. She does not sell weddings. She recognises visions. She hears the dream underneath the words. And then she begins the conversation that quietly changes everything.",
  },
];
---

<BaseLayout
  title="The House — Nix & Tayne | ICE Luxury Weddings Bali"
  description="ICE Luxury Weddings & Events — founded by Nix and Tayne. A mother-and-son house pairing 30+ years of legacy with modern innovation, technology, and a shared passion for extraordinary celebrations in Bali and worldwide."
>

  <!-- HERO -->
  <header class="relative isolate overflow-hidden bg-obsidian">
    <img
      src="https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/68f314cbea9084a6f18cb8a1/ddd547f76_IMG_1269.jpg"
      alt=""
      aria-hidden="true"
      width="1920"
      height="1080"
      class="absolute inset-0 -z-30 h-full w-full object-cover opacity-15"
    />
    <div class="absolute inset-0 -z-20 bg-gradient-to-b from-obsidian/90 via-midnight-deep/85 to-obsidian"></div>
    <Starfield />
    <div class="container-prose py-28 md:py-36">
      <SectionHeading
        as="h1"
        eyebrow="The House · Mother & Son"
        title="A mother, a son, and a shared passion for the extraordinary."
        intro="Nix gave thirty years to other people's love stories. Her son grew up watching, and chose to spend his life building the next chapter beside her. Together, they are taking on the world, one celebration at a time."
      />
    </div>
  </header>

  <!-- ORIGIN STORY -->
  <section class="bg-midnight-deep">
    <div class="container-prose grid gap-16 py-24 md:grid-cols-2 md:py-32">
      <div class="space-y-6 text-lg leading-relaxed text-silver reveal-on-scroll">
        <p>
          Every extraordinary story has a beginning.
        </p>
        <p>
          For over three decades, <span class="text-crystal">Nix</span> helped couples celebrate
          the most important days of their lives — earning a reputation as one of the world's most respected and
          trusted wedding professionals. What began as a passion evolved into something much greater.
        </p>
        <p>
          Together, mother and son united <span class="text-crystal">experience, creativity, innovation,
          and vision</span> to establish ICE Luxury Weddings &amp; Events. A company built on family
          values, genuine relationships, and a shared commitment to creating extraordinary celebrations.
        </p>
        <p>
          Today, that legacy continues to evolve through a new generation of innovation — while remaining
          grounded in the principles that built its foundation.
        </p>
        <p class="text-crystal">
          We don't simply plan weddings &amp; events — we create memories.
        </p>
      </div>
      <figure class="reveal-on-scroll self-center border-l border-burgundy-soft/50 pl-8">
        <blockquote class="font-display text-3xl leading-snug text-crystal sm:text-4xl">
          "When love leads the design, every detail becomes a reflection of the heart."
        </blockquote>
        <figcaption class="eyebrow mt-6 text-silver-soft">Nix · Founder &amp; Creative Director</figcaption>
      </figure>
    </div>
  </section>

  <!-- THREE PILLARS -->
  <section class="bg-obsidian sec-glow-y">
    <div class="container-prose py-20 md:py-24">
      <dl class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-silver/10 sm:grid-cols-3">
        <div class="flex flex-col gap-3 bg-midnight-deep/60 p-10 blue-border-r">
          <dt class="eyebrow text-champagne">Legacy</dt>
          <dd class="font-display text-5xl text-burgundy-bright">30+</dd>
          <p class="text-sm leading-relaxed text-silver">Years composing extraordinary celebrations across four continents.</p>
        </div>
        <div class="flex flex-col gap-3 bg-midnight-deep/60 p-10 blue-border-r">
          <dt class="eyebrow text-champagne">Innovation</dt>
          <dd class="font-display text-3xl text-burgundy-bright leading-tight">Creative Vision</dd>
          <p class="text-sm leading-relaxed text-silver">Future-focused design intelligence paired with generational instinct.</p>
        </div>
        <div class="flex flex-col gap-3 bg-midnight-deep/60 p-10">
          <dt class="eyebrow text-champagne">Technology</dt>
          <dd class="font-display text-3xl text-burgundy-bright leading-tight">Dream Builder</dd>
          <p class="text-sm leading-relaxed text-silver">The world's most advanced luxury wedding planning platform.</p>
        </div>
      </dl>
    </div>
  </section>

  <!-- FOUNDERS -->
  <section class="bg-midnight-deep">
    <div class="container-prose py-24 md:py-32">
      <SectionHeading
        eyebrow="Two Generations · One Vision"
        title="The people behind the house."
        intro="Tap the seal on each portrait to read their story."
      />
      <div class="mt-16 grid gap-10 md:grid-cols-2 md:gap-12">
        {founders.map((f) => (
          <FounderCard
            name={f.name}
            role={f.role}
            eyebrow={f.eyebrow}
            portraitLabel={f.portraitLabel}
            image={f.image}
            quote={f.quote}
            bio={f.bio}
            client:visible
          />
        ))}
      </div>
    </div>
  </section>

  <!-- THE TEAM -->
  <section class="bg-obsidian sec-glow">
    <div class="container-prose py-24 md:py-32">
      <SectionHeading
        eyebrow="The Heartbeat of ICE"
        title="The people who make the extraordinary feel effortless."
        intro="ICE is not one person. It is a house — built of individuals who chose this work not because it was a career, but because they could not imagine doing anything else. Every person here was chosen for something that cannot be listed on a résumé."
      />

      <TeamGrid members={teamMembers} client:visible />

      <p class="mt-14 text-center text-sm italic text-silver-soft">
        Together, we are more than a team. We are the quiet force behind every extraordinary celebration. We are ICE.
      </p>
    </div>
  </section>

  <!-- HOUSE PROMISE -->
  <section class="bg-midnight-deep sec-glow">
    <div class="container-prose py-24 md:py-28">
      <SectionHeading
        eyebrow="Our Standard"
        title="What we stand for, as a house."
        intro="Five commitments that hold regardless of where in the world we're composing, or how the technology evolves."
      />
      <HousePromise promises={promises} client:visible />
    </div>
  </section>

  <!-- OUR PROMISE -->
  <section class="bg-obsidian sec-glow">
    <div class="container-prose py-24 md:py-28">
      <div class="mx-auto max-w-3xl space-y-6 text-center reveal-on-scroll">
        <p class="eyebrow text-champagne">Our Promise</p>
        <blockquote class="font-display text-2xl leading-snug text-crystal sm:text-3xl lg:text-4xl">
          "Every celebration is approached with artistry, precision, and emotional depth. We listen,
          we dream alongside you, and we bring your story to life through details that reflect your
          style and soul. Our promise is simple: a flawless experience, fully present in every
          beautiful moment, no matter where in the world it unfolds."
        </blockquote>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-midnight-deep sec-glow">
    <div class="container-prose flex flex-col items-center py-20 text-center md:py-24">
      <IceLogo variant="mark" size="md" glow={true} class="text-champagne reveal-on-scroll" />
      <p class="eyebrow mt-7 text-champagne">Based in Bali · Composing worldwide</p>
      <p class="mx-auto mt-4 max-w-xl text-balance text-xl leading-relaxed text-crystal">
        Two generations united by one purpose: creating moments and memories that matter — not only
        for today, but for generations to come.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="/apply" class="btn-gold sheen">Begin Your Journey</a>
        <a href="/dream-builder" class="btn-outline">Explore Dream Builder</a>
      </div>
    </div>
  </section>

</BaseLayout>
