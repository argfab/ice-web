---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Starfield from '../components/Starfield.astro';

const press = (await getCollection('press')).sort((a, b) => a.data.order - b.data.order);

const stats = [
  { value: 30, suffix: '+', label: 'Years of Excellence' },
  { value: 500, suffix: '+', label: 'Celebrations Composed' },
  { value: 15, suffix: '+', label: 'Destinations' },
  { value: 4, suffix: '', label: 'Continents' },
];

const recognitions = [
  {
    category: 'Global Media',
    entries: [
      { outlet: 'Forbes', detail: 'Featured as a standard-bearer for the new era of destination celebrations' },
      { outlet: 'Vogue Bride', detail: 'Recognised for unparalleled luxury wedding design in Southeast Asia' },
      { outlet: 'Tatler', detail: "Listed among the world's most trusted luxury wedding houses" },
    ],
  },
  {
    category: 'Industry Standing',
    entries: [
      { outlet: '30+ Years', detail: 'Unbroken reputation built entirely on referral and word of mouth' },
      { outlet: 'By Application Only', detail: 'A limited number of celebrations each year — quality, never volume' },
      { outlet: "Bali's First", detail: 'Technology-powered luxury wedding architecture studio' },
    ],
  },
];
---

<BaseLayout
  title="Recognition — Press & Awards | ICE Luxury Weddings & Events Bali"
  description="ICE Luxury Weddings & Events — recognised by Forbes, Vogue Bride, and Tatler. 30+ years of luxury wedding excellence in Bali and worldwide."
>

  <!-- HERO -->
  <header class="relative isolate overflow-hidden bg-gradient-to-b from-obsidian via-midnight-deep to-obsidian">
    <Starfield />
    <div class="container-prose pt-28 md:pt-36 pb-10 md:pb-14">
      <SectionHeading
        as="h1"
        eyebrow="Recognition"
        title="Quietly, in remarkable company."
        intro="We rarely seek the spotlight — but the celebrations we compose, and the couples who trust us with them, have a way of finding it."
      />
    </div>
  </header>

  <!-- STATS -->
  <section class="bg-midnight-deep">
    <div class="container-prose py-16">
      <dl class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-silver/10 md:grid-cols-4">
        {stats.map((s) => (
          <div class="flex flex-col items-center justify-center gap-2 bg-obsidian/60 px-6 py-10 text-center reveal-on-scroll">
            <dt class="eyebrow text-silver-soft">{s.label}</dt>
            <dd class="font-display text-4xl text-champagne sm:text-5xl">
              <span class="stat-counter" data-target={s.value} data-suffix={s.suffix}>0{s.suffix}</span>
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- PRESS GRID -->
  <section class="bg-midnight-deep">
    <div class="container-prose pt-4 pb-24 md:pb-32">
      <p class="eyebrow text-center mb-12">Featured in</p>
      <ul class="grid gap-px overflow-hidden rounded-3xl border border-silver/10 sm:grid-cols-3">
        {press.map((p) => (
          <li class="press-item reveal-on-scroll flex flex-col items-center justify-center gap-3 bg-obsidian/60 px-8 py-16 text-center">
            <span class="font-display text-3xl tracking-wide text-crystal sm:text-4xl">
              {p.data.outlet}
            </span>
            {p.data.quote && (
              <p class="max-w-xs text-sm leading-relaxed text-silver/70 italic">"{p.data.quote}"</p>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- RECOGNITION CATEGORIES -->
  <section class="border-t border-silver/10 bg-obsidian">
    <div class="container-prose py-24 md:py-28">
      <div class="grid gap-16 md:grid-cols-2">
        {recognitions.map((r) => (
          <div class="reveal-on-scroll">
            <p class="eyebrow text-champagne">{r.category}</p>
            <ul class="mt-8 space-y-4">
              {r.entries.map((e) => (
                <li class="recog-card glass rounded-xl px-6 py-5">
                  <p class="font-display text-xl text-crystal">{e.outlet}</p>
                  <p class="mt-2 text-sm leading-relaxed text-silver">{e.detail}</p>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LEGACY STATEMENT -->
  <section class="border-t border-silver/10 bg-midnight-deep">
    <div class="container-prose py-20 text-center">
      <p class="eyebrow text-champagne">Thirty Years · One Standard</p>
      <p class="mx-auto mt-5 max-w-2xl text-balance text-lg leading-relaxed text-crystal">
        More than three decades composing the world's most extraordinary celebrations — and a
        modern house, powered by proprietary technology, built to carry that legacy forward.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="/apply" class="btn-gold sheen">Begin Your Journey</a>
        <a href="/the-house" class="btn-outline">Meet the house</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Shared sweep mixin */
  .recog-card,
  .press-item {
    position: relative;
    overflow: hidden;
    transition:
      background 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.4s ease,
      box-shadow 0.4s ease,
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .recog-card::before,
  .press-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      110deg,
      transparent 20%,
      rgba(255, 255, 255, 0.07) 45%,
      rgba(65, 105, 225, 0.11) 55%,
      transparent 80%
    );
    transform: translateX(-110%);
    transition: transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 1;
  }

  .recog-card:hover::before,
  .press-item:hover::before {
    transform: translateX(110%);
  }

  .recog-card:hover {
    background: rgba(27, 58, 140, 0.18);
    backdrop-filter: blur(20px);
    border-color: rgba(65, 105, 225, 0.40) !important;
    box-shadow: 0 0 28px rgba(65, 105, 225, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transform: translateY(-3px);
  }

  .press-item:hover {
    background: rgba(27, 58, 140, 0.12);
    box-shadow: inset 0 0 40px rgba(65, 105, 225, 0.08), 0 0 20px rgba(65, 105, 225, 0.10);
  }
</style>
