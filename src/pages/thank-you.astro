---
import BaseLayout from '../layouts/BaseLayout.astro';
import IceLogo from '../components/IceLogo.astro';
import Starfield from '../components/Starfield.astro';
---

<BaseLayout
  title="Thank You"
  description="Your application has been received by ICE Luxury Weddings & Events."
>
  <section class="relative isolate flex min-h-[85vh] items-center overflow-hidden bg-gradient-to-b from-obsidian via-midnight-deep to-obsidian">
    <Starfield />
    <div class="container-prose max-w-3xl py-24 text-center">
      <IceLogo variant="mark" size="md" glow={true} class="mx-auto text-champagne" />
      <p class="eyebrow mt-8">Application received</p>
      <div class="rule mx-auto mt-6" aria-hidden="true"></div>
      <h1 class="mt-8 text-balance text-4xl leading-tight text-crystal sm:text-5xl">
        Thank you. Your story is now with us.
      </h1>
      <p class="mx-auto mt-7 max-w-xl text-lg leading-relaxed text-silver">
        Every application is read personally by the house. If we feel we are the right hands for
        your celebration, you will hear from us within five days, discreetly, and with care.
      </p>
      <a href="/" class="btn-outline mt-10">Return home</a>
    </div>
  </section>
</BaseLayout>
